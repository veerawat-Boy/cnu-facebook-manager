    private async Task DisconnectPage(SavedPage page)
    {
        page.IsDisconnecting = true;
        StateHasChanged();

        try
        {
            var http = HttpFactory.CreateClient("BackendAPI");
            var payload = new
            {
                fbUserId = FbUserId,
                pageID = page.PageId
            };

            var json = System.Text.Json.JsonSerializer.Serialize(payload);
            var res = await http.PatchAsync("api/cnufacebook/DisconnectPage",
                new StringContent(json, System.Text.Encoding.UTF8, "application/json"));

            if (res.IsSuccessStatusCode)
            {
                pages.Remove(page);
            }
        }
        catch { }
        finally
        {
            page.IsDisconnecting = false;
            StateHasChanged();
        }
    }

    private bool isConnecting = false;

    private async Task AddNewPage()
    {
        if (isConnecting || string.IsNullOrWhiteSpace(FbUserId)) return;

        isConnecting = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var http = HttpFactory.CreateClient("BackendAPI");
            // ใช้ LongLivedToken ที่บันทึกไว้แล้วในฐานข้อมูล สร้าง session เพื่อดึงรายการเพจ
            // โดยไม่ต้องให้ผู้ใช้ Login Facebook ใหม่
            var res = await http.GetAsync(
                $"api/cnufacebook/CreateSessionFromToken?fbUserId={Uri.EscapeDataString(FbUserId!)}");

            if (res.IsSuccessStatusCode)
            {
                var body = await res.Content.ReadAsStringAsync();
                var doc = System.Text.Json.JsonDocument.Parse(body);
                string sessionKey = doc.RootElement.GetProperty("sessionKey").GetString()!;
                Nav.NavigateTo($"/select-pages?fb_session={Uri.EscapeDataString(sessionKey)}");
            }
            else
            {
                // ไม่พบ token ใน DB → เปิด Facebook login popup แทน
                var loginRes = await http.GetAsync("api/cnufacebook/GetFacebookLoginUrl");
                if (loginRes.IsSuccessStatusCode)
                {
                    var loginBody = await loginRes.Content.ReadAsStringAsync();
                    var loginDoc = System.Text.Json.JsonDocument.Parse(loginBody);
                    string loginUrl = loginDoc.RootElement.GetProperty("loginUrl").GetString()!;
                    await JS.InvokeVoidAsync("open", loginUrl, "_blank", "width=700,height=600,left=400,top=100");
                }
                else
                {
                    errorMessage = "ไม่สามารถเชื่อมต่อ Facebook ได้ กรุณาลองใหม่";
                }
            }
        }
        catch
        {
            errorMessage = "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่";
        }
        finally
        {
            isConnecting = false;
            StateHasChanged();
        }
    }

    private class SavedPage
    {
        public string PageId { get; set; } = "";
        public string PageName { get; set; } = "";
        public string OpenStatus { get; set; } = "1";
        //public string PrompSet { get; set; } = "";
        //public bool IsEditingPromp { get; set; } = false;
        //public string EditingPrompValue { get; set; } = "";
        //public bool IsSavingPromp { get; set; } = false;
        public bool IsDisconnecting { get; set; } = false;
    }
}