@page "/"
@rendermode InteractiveServer
@inject NavigationManager Nav

<div class="page-card">
    <div class="page-card-body">
        <div class="text-center mb-4">
            <div class="mb-3">
                <svg width="64" height="64" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="32" cy="32" r="32" fill="#5B2D8A" />
                    <path d="M32 14C25.4 14 20 19.4 20 26C20 29.9 21.8 33.4 24.6 35.7C20.5 37.3 18 41.1 18 45.4V47H46V45.4C46 41.1 43.5 37.3 39.4 35.7C42.2 33.4 44 29.9 44 26C44 19.4 38.6 14 32 14ZM32 17C36.9 17 41 21.1 41 26C41 30.9 36.9 35 32 35C27.1 35 23 30.9 23 26C23 21.1 27.1 17 32 17Z" fill="white" />
                </svg>
            </div>
            <h5 class="page-title">เข้าสู่ระบบ</h5>
            <p class="page-subtitle">กรุณากดปุ่มเพื่อเข้าสู่ระบบ</p>
        </div>

        <div class="d-flex justify-content-center">
            <button class="btn-next"
                    @onclick="HandleLogin"
                    disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                }
                เข้าสู่ระบบ
            </button>
        </div>
    </div>
</div>

@code {
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        StateHasChanged();
        await Task.Delay(50);
        Nav.NavigateTo("/connect");
    }
}
