@page "/select-pages"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IHttpClientFactory HttpFactory

<div class="page-card">
    <div class="page-card-body">
        <div class="text-center mb-3">
            <h5 class="page-title">กรุณาเลือกเพจที่ต้องการเชื่อมต่อ</h5>
            <p class="page-subtitle">สามารถใช้งานได้หลายเพจ โดยไม่มีค่าบริการเพิ่มเติม</p>
        </div>

        @if (isLoading)
        {
            <div class="text-center py-4">
                <div class="spinner-border text-secondary" role="status"></div>
                <p class="text-muted mt-2 small">กำลังโหลดรายการเพจ...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger small" role="alert">@errorMessage</div>
            <div class="text-center mt-3">
                <a href="/" class="btn-next">กลับหน้าหลัก</a>
            </div>
        }
        else
        {
            <div class="page-list-item">
                <div class="page-info">
                    <span class="page-name fw-semibold">เลือกทั้งหมด</span>
                </div>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input"
                           type="checkbox"
                           role="switch"
                           checked="@allSelected"
                           @onchange="ToggleAll" />
                </div>
            </div>

            @foreach (var page in pages)
            {
                <div class="page-list-item">
                    <div class="page-info">
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input"
                                   type="checkbox"
                                   role="switch"
                                   @bind="page.IsSelected" />
                        </div>
                        <span class="page-name">@(page.PageName)</span>
                    </div>
                    <div class="page-avatar-wrapper">
                        @if (!string.IsNullOrEmpty(page.PictureUrl))
                        {
                            <img src="@(page.PictureUrl)" class="page-avatar" alt="@(page.PageName)" />
                        }
                        else
                        {
                            <div class="page-avatar-placeholder">
                                @(page.PageName.Length > 0 ? page.PageName[0].ToString().ToUpper() : "P")
                            </div>
                        }
                        <span class="fb-badge"></span>
                    </div>
                </div>
            }

            @if (pages.Count == 0)
            {
                <p class="text-center text-muted py-3 small">ไม่พบเพจที่คุณเป็นผู้ดูแล</p>
            }

            @if (!string.IsNullOrEmpty(saveError))
            {
                <div class="alert alert-danger small mt-3" role="alert">@saveError</div>
            }

            <div class="d-flex justify-content-center mt-4">
                <button class="btn-next"
                        @onclick="SavePages"
                        disabled="@(isSaving || !pages.Any(p => p.IsSelected))">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm" role="status"></span>
                        <span>กำลังบันทึก...</span>
                    }
                    else
                    {
                        <span>ถัดไป &gt;</span>
                    }
                </button>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "fb_session")]
    public string? FbSession { get; set; }

    [SupplyParameterFromQuery(Name = "fb_error")]
    public string? FbError { get; set; }

    private List<PageItem> pages = new();
    private string fbUserId = "";
    private string longLivedToken = "";
    private bool isLoading = true;
    private bool isSaving = false;
    private string errorMessage = "";
    private string saveError = "";

    private bool allSelected => pages.Count > 0 && pages.All(p => p.IsSelected);

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(FbError))
        {
            errorMessage = "การเชื่อมต่อ Facebook ถูกยกเลิก กรุณาลองใหม่";
            isLoading = false;
            return;
        }

        if (string.IsNullOrEmpty(FbSession))
        {
            errorMessage = "ไม่พบ session กรุณา Login Facebook ใหม่";
            isLoading = false;
            return;
        }

        await LoadPages();
    }

    private async Task LoadPages()
    {
        try
        {
            var http = HttpFactory.CreateClient("BackendAPI");
            var res = await http.GetAsync(
                $"api/cnufacebook/GetFacebookPages?sessionKey={Uri.EscapeDataString(FbSession!)}");

            if (res.IsSuccessStatusCode)
            {
                var body = await res.Content.ReadAsStringAsync();
                var doc = System.Text.Json.JsonDocument.Parse(body);

                fbUserId = doc.RootElement.GetProperty("fbUserId").GetString() ?? "";
                longLivedToken = doc.RootElement.TryGetProperty("longLivedToken", out var lt) ? lt.GetString() ?? "" : "";

                pages = doc.RootElement
                    .GetProperty("pages")
                    .EnumerateArray()
                    .Select(p => new PageItem
                    {
                        PageId = p.GetProperty("pageId").GetString() ?? "",
                        PageName = p.GetProperty("pageName").GetString() ?? "",
                        PictureUrl = p.TryGetProperty("pictureUrl", out var pic) ? pic.GetString() ?? "" : "",
                        PageAccessToken = p.TryGetProperty("pageAccessToken", out var tok) ? tok.GetString() ?? "" : "",
                        IsSelected = true
                    })
                    .ToList();
            }
            else
            {
                errorMessage = "Session หมดอายุ กรุณา Login Facebook ใหม่";
            }
        }
        catch
        {
            errorMessage = "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleAll(ChangeEventArgs e)
    {
        bool val = (bool)(e.Value ?? false);
        foreach (var p in pages) p.IsSelected = val;
    }

    private async Task SavePages()
    {
        var selected = pages.Where(p => p.IsSelected).ToList();
        if (selected.Count == 0) return;

        isSaving = true;
        saveError = "";
        StateHasChanged();

        try
        {
            var http = HttpFactory.CreateClient("BackendAPI");
            var payload = new
            {
                longToken = longLivedToken,
                createUserId = fbUserId,
                pages = selected.Select(p => new
                {
                    pageId = p.PageId,
                    pageName = p.PageName,
                    pageAccessToken = p.PageAccessToken
                })
            };

            var json = System.Text.Json.JsonSerializer.Serialize(payload);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            var res = await http.PostAsync("api/cnufacebook/SaveSelectedPages", content);

            if (res.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/dashboard?fbUserId={Uri.EscapeDataString(fbUserId)}");
            }
            else
            {
                saveError = "บันทึกไม่สำเร็จ กรุณาลองใหม่";
            }
        }
        catch
        {
            saveError = "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่";
        }
        finally
        {
            isSaving = false;
        }
    }

    private class PageItem
    {
        public string PageId { get; set; } = "";
        public string PageName { get; set; } = "";
        public string PictureUrl { get; set; } = "";
        public string PageAccessToken { get; set; } = "";
        public bool IsSelected { get; set; }
    }
}