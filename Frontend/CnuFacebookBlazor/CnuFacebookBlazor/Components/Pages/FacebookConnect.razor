@page "/connect"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS

<div class="page-card">
    <div class="page-card-body">
        <div class="text-center mb-4">
            <h5 class="page-title">เชื่อมต่อบัญชีของคุณ</h5>
            <p class="page-subtitle">เลือกแพลตฟอร์มที่ต้องการเชื่อมต่อ</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger py-2 small mb-3" role="alert">@errorMessage</div>
        }

        <div class="d-flex flex-column align-items-center gap-3 mb-4">
            <button class="btn-facebook" @onclick="LoginWithFacebook" disabled="@(isLoadingFb || isLoadingLine)">
                @if (isLoadingFb)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span>กำลังโหลด...</span>
                }
                else
                {
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                    </svg>
                    <span>Log in with Facebook</span>
                }
            </button>

            <button class="btn-line" @onclick="LoginWithLine" disabled="@(isLoadingFb || isLoadingLine)">
                @if (isLoadingLine)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span>กำลังโหลด...</span>
                }
                else
                {
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19.952 10.159C19.952 6.011 15.837 2.625 10.774 2.625C5.712 2.625 1.597 6.011 1.597 10.159C1.597 13.861 4.823 16.961 9.206 17.59C9.502 17.654 9.906 17.786 10.011 18.039C10.106 18.27 10.073 18.626 10.042 18.858C10.042 18.858 9.937 19.495 9.915 19.617C9.878 19.849 9.733 20.506 10.774 20.065C11.815 19.625 16.378 16.802 18.467 14.42C19.889 12.832 19.952 11.583 19.952 10.159ZM7.697 12.386H6.004C5.775 12.386 5.588 12.198 5.588 11.967V8.726C5.588 8.496 5.775 8.308 6.004 8.308C6.234 8.308 6.421 8.496 6.421 8.726V11.549H7.697C7.927 11.549 8.114 11.737 8.114 11.967C8.114 12.198 7.927 12.386 7.697 12.386ZM9.139 11.967C9.139 12.198 8.952 12.386 8.722 12.386C8.492 12.386 8.305 12.198 8.305 11.967V8.726C8.305 8.496 8.492 8.308 8.722 8.308C8.952 8.308 9.139 8.496 9.139 8.726V11.967ZM12.778 11.967C12.778 12.158 12.658 12.33 12.478 12.373C12.431 12.386 12.383 12.392 12.336 12.392C12.197 12.392 12.066 12.33 11.977 12.22L10.527 10.35V11.967C10.527 12.198 10.34 12.386 10.11 12.386C9.88 12.386 9.693 12.198 9.693 11.967V8.726C9.693 8.535 9.813 8.363 9.993 8.32C10.04 8.308 10.088 8.302 10.135 8.302C10.274 8.302 10.405 8.363 10.494 8.474L11.944 10.344V8.726C11.944 8.496 12.131 8.308 12.361 8.308C12.591 8.308 12.778 8.496 12.778 8.726V11.967ZM15.511 9.559C15.741 9.559 15.928 9.747 15.928 9.977C15.928 10.208 15.741 10.395 15.511 10.395H14.235V11.132H15.511C15.741 11.132 15.928 11.32 15.928 11.55C15.928 11.78 15.741 11.968 15.511 11.968H13.818C13.589 11.968 13.402 11.78 13.402 11.55V8.309H13.407C13.407 8.297 13.402 8.285 13.402 8.273C13.402 8.043 13.589 7.855 13.818 7.855H15.511C15.741 7.855 15.928 8.043 15.928 8.273C15.928 8.503 15.741 8.691 15.511 8.691H14.235V9.559H15.511Z"/>
                    </svg>
                    <span>Log in with LINE</span>
                }
            </button>
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <a href="/" class="text-muted text-decoration-none small">&larr; ย้อนกลับ</a>
            <button class="btn-next" @onclick="LoginWithFacebook" disabled="@(isLoadingFb || isLoadingLine)">
                ถัดไป &gt;
            </button>
        </div>
    </div>
</div>

@code {
    private bool isLoadingFb = false;
    private bool isLoadingLine = false;
    private string errorMessage = "";

    private async Task LoginWithFacebook()
    {
        isLoadingFb = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var http = HttpFactory.CreateClient("BackendAPI");
            var res = await http.GetAsync("api/cnufacebook/GetFacebookLoginUrl");

            if (res.IsSuccessStatusCode)
            {
                var body = await res.Content.ReadAsStringAsync();
                var doc = System.Text.Json.JsonDocument.Parse(body);
                string loginUrl = doc.RootElement.GetProperty("loginUrl").GetString()!;
                await JS.InvokeVoidAsync("open", loginUrl, "_blank", "width=700,height=600,left=400,top=100");
            }
            else
            {
                errorMessage = "ไม่สามารถสร้าง URL สำหรับ Login ได้ กรุณาลองใหม่";
            }
        }
        catch
        {
            errorMessage = "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่";
        }
        finally
        {
            isLoadingFb = false;
        }
    }

    private async Task LoginWithLine()
    {
        isLoadingLine = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var http = HttpFactory.CreateClient("BackendAPI");
            var res = await http.GetAsync("api/cnufacebook/GetLineLoginUrl");

            if (res.IsSuccessStatusCode)
            {
                var body = await res.Content.ReadAsStringAsync();
                var doc = System.Text.Json.JsonDocument.Parse(body);
                string loginUrl = doc.RootElement.GetProperty("loginUrl").GetString()!;
                Nav.NavigateTo(loginUrl, forceLoad: true);
            }
            else
            {
                errorMessage = "ไม่สามารถสร้าง URL สำหรับ LINE Login ได้ กรุณาลองใหม่";
                isLoadingLine = false;
            }
        }
        catch
        {
            errorMessage = "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่";
            isLoadingLine = false;
        }
    }
}
