@page "/data-deletion"
@inject NavigationManager Nav

@code {
    private string? ConfirmationCode;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        ConfirmationCode = query["code"];
    }
}

<div class="policy-wrapper">
    <div class="policy-card">
        <div class="policy-header">
            <svg width="36" height="36" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="20" cy="20" r="20" fill="#5B2D8A" />
                <path d="M26 14H22.5L21.5 13H18.5L17.5 14H14V16H26V14ZM15 27C15 28.1 15.9 29 17 29H23C24.1 29 25 28.1 25 27V17H15V27Z" fill="white" />
            </svg>
            <div>
                <h1 class="policy-title">User Data Deletion</h1>
                <p class="policy-meta">CNU Facebook Manager &nbsp;|&nbsp; Effective from January 1, 2025</p>
            </div>
        </div>

        <section>
            <h2>1. Data We Collect</h2>
            <p>CNU Facebook Manager collects the following data when you connect your Facebook account:</p>
            <ul>
                <li><strong>Profile information</strong> — Username and profile picture from Facebook</li>
                <li><strong>Page token</strong> — Used to send reply messages on behalf of your page</li>
                <li><strong>Page settings</strong> — Prompt and auto-reply configuration for each page</li>
            </ul>
        </section>

        <section>
            <h2>2. How to Delete Your Data</h2>
            <p>You can request deletion of all your data from the system in 2 ways:</p>

            <h3>Method 1 — Via Facebook (Automatic)</h3>
            <ol>
                <li>Go to <strong>Facebook Settings</strong></li>
                <li>Navigate to <strong>Privacy → Apps and Websites</strong></li>
                <li>Find <strong>CNUChatBot2026</strong> and click <strong>Remove</strong></li>
                <li>We will be notified automatically via a Callback URL and your data will be deleted immediately</li>
            </ol>

            <h3>Method 2 — Contact Us Directly</h3>
            <p>
                Send an email to <a href="mailto:cnuprogrammer2021@gmail.com">cnuprogrammer2021@gmail.com</a>
                with the subject <strong>"Data Deletion Request — CNU Facebook Manager"</strong>
                along with your Facebook account name
            </p>
        </section>

        @if (!string.IsNullOrEmpty(ConfirmationCode))
        {
            <section class="status-box">
                <h2>Deletion Status</h2>
                <p>Your data deletion request has been recorded</p>
                <p>Confirmation code: <strong>@ConfirmationCode</strong></p>
                <p>Your data will be deleted within 30 business days</p>
            </section>
        }

        <section>
            <h2>3. Processing Time</h2>
            <p>
                We will delete your data within <strong>30 business days</strong>
                from the date the request is received, and will notify you of the outcome via email
            </p>
        </section>

        <section>
            <h2>4. Data That Cannot Be Deleted</h2>
            <p>
                Data stored within Meta/Facebook's systems must be deleted directly through Facebook's own channels,
                which is outside the scope of what we can manage
            </p>
        </section>

        <section>
            <h2>5. Contact Us</h2>
            <p>
                If you have any further questions, please contact:<br />
                <strong>CNU Facebook Manager</strong><br />
                Email: <a href="mailto:cnuprogrammer2021@gmail.com">cnuprogrammer2021@gmail.com</a>
            </p>
        </section>

        <div class="policy-footer">
            <a href="/" class="text-muted text-decoration-none small">&larr; Back to home</a>
        </div>
    </div>
</div>

<style>
    .policy-wrapper {
        max-width: 760px;
        margin: 0 auto;
        padding: 32px 16px 48px;
    }

    .policy-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 24px rgba(0, 0, 0, 0.08);
        padding: 40px 48px;
    }

    .policy-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
        padding-bottom: 24px;
        border-bottom: 2px solid #f0f0f0;
    }

    .policy-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #5B2D8A;
        margin: 0;
    }

    .policy-meta {
        font-size: 0.8rem;
        color: #888;
        margin: 4px 0 0;
    }

    section {
        margin-bottom: 28px;
    }

    section h2 {
        font-size: 1rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
    }

    section h3 {
        font-size: 0.9rem;
        font-weight: 600;
        color: #444;
        margin: 14px 0 8px;
    }

    section p, section li {
        font-size: 0.9rem;
        color: #555;
        line-height: 1.7;
    }

    section ul, section ol {
        padding-left: 20px;
        margin-bottom: 0;
    }

    section a {
        color: #5B2D8A;
    }

    .policy-footer {
        margin-top: 32px;
        padding-top: 20px;
        border-top: 1px solid #f0f0f0;
    }

    @@media (max-width: 600px) {
        .policy-card { padding: 24px 20px; }
        .policy-header { flex-direction: column; align-items: flex-start; gap: 10px; }
    }
</style>
