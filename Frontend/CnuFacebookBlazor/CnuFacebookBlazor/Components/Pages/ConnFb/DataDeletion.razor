@page "/data-deletion"
@inject NavigationManager Nav

@code {
    private string? ConfirmationCode;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        ConfirmationCode = query["code"];
    }
}

<div class="policy-wrapper">
    <div class="policy-card">
        <div class="policy-header">
            <svg width="36" height="36" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="20" cy="20" r="20" fill="#5B2D8A" />
                <path d="M26 14H22.5L21.5 13H18.5L17.5 14H14V16H26V14ZM15 27C15 28.1 15.9 29 17 29H23C24.1 29 25 28.1 25 27V17H15V27Z" fill="white" />
            </svg>
            <div>
                <h1 class="policy-title">การลบข้อมูลผู้ใช้</h1>
                <p class="policy-meta">CNU Facebook Manager &nbsp;|&nbsp; มีผลบังคับใช้ตั้งแต่ 1 มกราคม 2568</p>
            </div>
        </div>

        <section>
            <h2>1. ข้อมูลที่เราจัดเก็บ</h2>
            <p>CNU Facebook Manager จัดเก็บข้อมูลต่อไปนี้เมื่อท่านเชื่อมต่อบัญชี Facebook:</p>
            <ul>
                <li><strong>ข้อมูลโปรไฟล์</strong> — ชื่อผู้ใช้และรูปโปรไฟล์จาก Facebook</li>
                <li><strong>Token ของเพจ</strong> — ใช้สำหรับส่งข้อความตอบกลับในนามเพจของท่าน</li>
                <li><strong>การตั้งค่าเพจ</strong> — Prompt และการตั้งค่าการตอบกลับอัตโนมัติของแต่ละเพจ</li>
            </ul>
        </section>

        <section>
            <h2>2. วิธีลบข้อมูลของท่าน</h2>
            <p>ท่านสามารถขอให้ลบข้อมูลทั้งหมดออกจากระบบได้ 2 วิธี:</p>

            <h3>วิธีที่ 1 — ผ่าน Facebook (อัตโนมัติ)</h3>
            <ol>
                <li>เข้าสู่ <strong>การตั้งค่า Facebook</strong></li>
                <li>ไปที่ <strong>ความเป็นส่วนตัว → แอปพลิเคชันและเว็บไซต์</strong></li>
                <li>ค้นหา <strong>CNUChatBot2026</strong> แล้วกด <strong>ลบ</strong></li>
                <li>ระบบจะแจ้งมายังเราโดยอัตโนมัติผ่าน Callback URL และลบข้อมูลทันที</li>
            </ol>

            <h3>วิธีที่ 2 — ติดต่อโดยตรง</h3>
            <p>
                ส่งอีเมลมาที่ <a href="mailto:cnuprogrammer2021@gmail.com">cnuprogrammer2021@gmail.com</a>
                โดยระบุหัวข้อว่า <strong>"ขอลบข้อมูล — CNU Facebook Manager"</strong>
                พร้อมชื่อบัญชี Facebook ของท่าน
            </p>
        </section>

        @if (!string.IsNullOrEmpty(ConfirmationCode))
        {
            <section class="status-box">
                <h2>สถานะการลบข้อมูล</h2>
                <p>คำขอลบข้อมูลของท่านได้รับการบันทึกแล้ว</p>
                <p>รหัสยืนยัน: <strong>@ConfirmationCode</strong></p>
                <p>ข้อมูลของท่านจะถูกลบภายใน 30 วันทำการ</p>
            </section>
        }

        <section>
            <h2>3. ระยะเวลาดำเนินการ</h2>
            <p>
                เราจะดำเนินการลบข้อมูลของท่านภายใน <strong>30 วันทำการ</strong>
                นับจากวันที่ได้รับคำขอ และจะแจ้งผลการดำเนินการกลับมายังอีเมลของท่าน
            </p>
        </section>

        <section>
            <h2>4. ข้อมูลที่ไม่สามารถลบได้</h2>
            <p>
                ข้อมูลที่อยู่ในระบบของ Meta/Facebook ต้องดำเนินการลบผ่านช่องทางของ Facebook โดยตรง
                ซึ่งอยู่นอกเหนือขอบเขตที่เราสามารถจัดการได้
            </p>
        </section>

        <section>
            <h2>5. ติดต่อเรา</h2>
            <p>
                หากมีข้อสงสัยเพิ่มเติม กรุณาติดต่อ:<br />
                <strong>CNU Facebook Manager</strong><br />
                อีเมล: <a href="mailto:cnuprogrammer2021@gmail.com">cnuprogrammer2021@gmail.com</a>
            </p>
        </section>

        <div class="policy-footer">
            <a href="/" class="text-muted text-decoration-none small">&larr; กลับหน้าหลัก</a>
        </div>
    </div>
</div>

<style>
    .policy-wrapper {
        max-width: 760px;
        margin: 0 auto;
        padding: 32px 16px 48px;
    }

    .policy-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 24px rgba(0, 0, 0, 0.08);
        padding: 40px 48px;
    }

    .policy-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
        padding-bottom: 24px;
        border-bottom: 2px solid #f0f0f0;
    }

    .policy-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #5B2D8A;
        margin: 0;
    }

    .policy-meta {
        font-size: 0.8rem;
        color: #888;
        margin: 4px 0 0;
    }

    section {
        margin-bottom: 28px;
    }

    section h2 {
        font-size: 1rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
    }

    section h3 {
        font-size: 0.9rem;
        font-weight: 600;
        color: #444;
        margin: 14px 0 8px;
    }

    section p, section li {
        font-size: 0.9rem;
        color: #555;
        line-height: 1.7;
    }

    section ul, section ol {
        padding-left: 20px;
        margin-bottom: 0;
    }

    section a {
        color: #5B2D8A;
    }

    .policy-footer {
        margin-top: 32px;
        padding-top: 20px;
        border-top: 1px solid #f0f0f0;
    }

    @@media (max-width: 600px) {
        .policy-card { padding: 24px 20px; }
        .policy-header { flex-direction: column; align-items: flex-start; gap: 10px; }
    }
</style>
